{:paths ["src" "test"]
 :tasks {test {:doc "Run the cljc contract + behavioral test under babashka"
               :extra-paths ["test"]
               :requires ([hl7-fhir.main-test] [hl7-fhir.validation-test])
               :task (let [{:keys [fail error]} (clojure.test/run-tests
                                                  'hl7-fhir.main-test
                                                  'hl7-fhir.validation-test)]
                       (System/exit (if (pos? (+ fail error)) 1 0)))}}}
